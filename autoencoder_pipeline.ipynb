# FULL PIPELINE: ETa → Autoencoder → SOM → Köppen GIS VALIDATION
# INPUT: CSV + Köppen Shapefile
# --- 0. INSTALL DEPENDENCIES ---
!pip install -q minisom geopandas contextily rasterio shapely openpyxl

import numpy as np
import pandas as pd
import matplotlib.pyplot as plt
import seaborn as sns
import geopandas as gpd
import contextily as ctx

from shapely.geometry import Point

import tensorflow as tf
from tensorflow.keras import layers, Model, callbacks

from minisom import MiniSom
from sklearn.preprocessing import MinMaxScaler
from sklearn.cluster import KMeans
from sklearn.metrics import (
    confusion_matrix, cohen_kappa_score,
    adjusted_rand_score, silhouette_score,
    calinski_harabasz_score, davies_bouldin_score
)

from google.colab import files
import warnings
warnings.filterwarnings("ignore")

np.random.seed(42)
tf.random.set_seed(42)

# ============================================================
# 1. LOAD CSV DATA (ETa)
# Expected columns:
# lon | lat | ETa_1 ... ETa_528
# ============================================================

print("Upload CSV file (ETa dataset)")
uploaded = files.upload()
csv_file = list(uploaded.keys())[0]

df = pd.read_csv(csv_file)

# detect coordinate columns
lon_col = "lon"
lat_col = "lat"

coords = df[[lon_col, lat_col]].values

# time-series part
ts_cols = [c for c in df.columns if c not in [lon_col, lat_col]]
X = df[ts_cols].values.astype(np.float32)

print("Data shape:", X.shape)

# ============================================================
# 2. LOAD KÖPPEN SHAPEFILE
# ============================================================

print("Upload Köppen-Geiger shapefile (.shp + files)")
uploaded = files.upload()

# assume main .shp file
shp_file = [f for f in uploaded.keys() if f.endswith(".shp")][0]

koppen_gdf = gpd.read_file(shp_file).to_crs("EPSG:4326")

# IMPORTANT: adjust this column name based on dataset
# usually: "class", "label", "koeppen", "gridcode"
koppen_col = koppen_gdf.columns[0]

print("Köppen classes column assumed:", koppen_col)

# ============================================================
# 3. SPATIAL JOIN (points → Köppen class)
# ============================================================

points_gdf = gpd.GeoDataFrame(
    df,
    geometry=[Point(xy) for xy in coords],
    crs="EPSG:4326"
)

joined = gpd.sjoin(points_gdf, koppen_gdf, how="left", predicate="intersects")

df["koppen"] = joined[koppen_col].values

# drop NaN
df = df.dropna(subset=["koppen"]).reset_index(drop=True)

X = df[ts_cols].values.astype(np.float32)

print("After spatial join:", X.shape)

# ============================================================
# 4. NORMALIZATION
# ============================================================

scaler = MinMaxScaler()
X_scaled = scaler.fit_transform(X)

# train/val split
idx = np.random.permutation(len(X_scaled))
split = int(0.8 * len(X_scaled))

train_idx, val_idx = idx[:split], idx[split:]

X_train = X_scaled[train_idx]
X_val   = X_scaled[val_idx]
X_all   = X_scaled

# ============================================================
# 5. AUTOENCODER (528 → 256 → 64 → 3)
# ============================================================

INPUT_DIM = X.shape[1]
LATENT_DIM = 3

def build_autoencoder():
    inp = layers.Input(shape=(INPUT_DIM,))
    
    x = layers.Dense(256, activation='relu')(inp)
    x = layers.Dense(64, activation='relu')(x)
    z = layers.Dense(LATENT_DIM, activation='relu', name="latent")(x)

    x = layers.Dense(64, activation='relu')(z)
    x = layers.Dense(256, activation='relu')(x)
    out = layers.Dense(INPUT_DIM, activation='sigmoid')(x)

    ae = Model(inp, out)
    encoder = Model(inp, z)

    return ae, encoder

ae, encoder = build_autoencoder()

ae.compile(optimizer="adam", loss="mse")

es = callbacks.EarlyStopping(patience=10, restore_best_weights=True)

history = ae.fit(
    X_train, X_train,
    validation_data=(X_val, X_val),
    epochs=50,
    batch_size=32,
    callbacks=[es],
    verbose=1
)

plt.plot(history.history["loss"], label="train")
plt.plot(history.history["val_loss"], label="val")
plt.legend()
plt.title("Autoencoder Loss")
plt.show()

# latent space
Z = encoder.predict(X_all)

# ============================================================
# 6. SOM
# ============================================================

som = MiniSom(
    x=20, y=20,
    input_len=LATENT_DIM,
    sigma=1.0,
    learning_rate=0.1,
    neighborhood_function='gaussian',
    random_seed=42
)

som.random_weights_init(Z)
som.train_random(Z, 200, verbose=True)

bmu = np.array([som.winner(z) for z in Z])
codebook = som.get_weights().reshape(400, LATENT_DIM)

# ============================================================
# 7. KMEANS ON CODEBOOK
# ============================================================

K_RANGE = range(3, 10)
scores = []

for k in K_RANGE:
    km = KMeans(n_clusters=k, n_init=10, random_state=42)
    labels = km.fit_predict(codebook)
    scores.append(silhouette_score(codebook, labels))

best_k = list(K_RANGE)[np.argmax(scores)]

km_final = KMeans(n_clusters=best_k, n_init=10, random_state=42)
cb_labels = km_final.fit_predict(codebook)

flat_bmu = bmu[:,0]*20 + bmu[:,1]
clusters = cb_labels[flat_bmu]

df["cluster"] = clusters

# ============================================================
# 8. Köppen VALIDATION
# ============================================================

# majority mapping
map_dict = df.groupby("cluster")["koppen"].agg(lambda x: x.mode()[0]).to_dict()
df["pred_koppen"] = df["cluster"].map(map_dict)

y_true = df["koppen"]
y_pred = df["pred_koppen"]

OA = np.mean(y_true == y_pred)
kappa = cohen_kappa_score(y_true, y_pred)
ari = adjusted_rand_score(y_true, y_pred)

print("OA:", OA, "Kappa:", kappa, "ARI:", ari)

cm = confusion_matrix(y_true, y_pred)

plt.figure(figsize=(8,6))
sns.heatmap(cm, annot=True, fmt="d")
plt.title("Confusion Matrix")
plt.show()

# ============================================================
# 9. GIS MAP (REAL Köppen BOUNDARIES)
# ============================================================

df["geometry"] = points_gdf.geometry
gdf = gpd.GeoDataFrame(df, geometry="geometry", crs="EPSG:4326").to_crs(3857)

fig, ax = plt.subplots(figsize=(10,8))

koppen_gdf.to_crs(3857).plot(ax=ax, alpha=0.3, color="lightgrey")

gdf.plot(
    ax=ax,
    column="cluster",
    cmap="tab20",
    markersize=3,
    legend=True
)

ctx.add_basemap(ax, source=ctx.providers.OpenStreetMap.Mapnik)

plt.title("ETa-based Hydroclimate Clusters vs Köppen")
plt.show()

# ============================================================
# 10. SAVE OUTPUT
# ============================================================

df.to_csv("final_output.csv", index=False)

print("DONE ✔")
